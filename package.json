{
  "name": "request-mock-lite",
  "version": "0.1.13",
  "description": "A lightweight Chrome extension for capturing API requests and managing fetch/XHR response mocks.",
  "private": true,
  "scripts": {
    "dev:landing": "vite --host 127.0.0.1",
    "build:landing": "vite build",
    "preview:landing": "vite preview --host 127.0.0.1",
    "build:vendor": "esbuild src/editor/codemirror-entry.js --bundle --format=iife --target=chrome100 --outfile=src/vendor/codemirror.bundle.js",
    "package": "npm run build:vendor && ./scripts/package.sh",
    "version": "node scripts/sync-version.mjs && git add manifest.json",
    "postversion": "git push origin HEAD && git push origin --tags"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eijil/request-mock-lite.git"
  },
  "keywords": [],
  "author": "jiel",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/eijil/request-mock-lite/issues"
  },
  "homepage": "https://github.com/eijil/request-mock-lite#readme",
  "devDependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/language": "^6.12.3",
    "@codemirror/lint": "^6.9.6",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.0",
    "@lezer/highlight": "^1.2.3",
    "@tailwindcss/vite": "^4.3.1",
    "@vitejs/plugin-react": "^6.0.2",
    "esbuild": "^0.28.1",
    "tailwindcss": "^4.3.1",
    "vite": "^8.0.16"
  },
  "dependencies": {
    "lucide-react": "^1.21.0",
    "motion": "^12.40.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  }
}
